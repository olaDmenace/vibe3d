# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AI — Anthropic Claude (for editor chat commands)
ANTHROPIC_API_KEY=sk-ant-api03-your-key

# 3D Generation — Meshy (primary provider, better hard-surface)
MESHY_API_KEY=your-meshy-api-key

# 3D Generation — Tripo3D (secondary provider, better organic shapes)
TRIPO_API_KEY=your-tripo-api-key

# Whop — Billing & Payments
WHOP_API_KEY=your-whop-api-key
WHOP_WEBHOOK_SECRET=your-whop-webhook-secret
WHOP_COMPANY_ID=biz_xxxxxxxxxxxxx

# Supabase — Service Role (for webhook handlers, NOT client-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — Email provider
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Vibe3D <hello@yourdomain.com>
